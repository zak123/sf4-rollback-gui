// Windows version resource, configured per target by
// sf4e_add_version_resource in CMakeLists.txt. Numeric constants are
// used instead of winres.h macros so the template compiles under any
// SDK layout. FILEOS 0x40004 = VOS_NT_WINDOWS32; FILETYPE 0x1 = app,
// 0x2 = dll.
1 VERSIONINFO
FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE @VER_FILETYPE@
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "sf4-rollback-gui contributors"
            VALUE "FileDescription", "@VER_DESCRIPTION@"
            VALUE "FileVersion", "@PROJECT_VERSION@"
            VALUE "InternalName", "@VER_FILENAME@"
            VALUE "LegalCopyright", "MIT License- adanducci and the sf4-rollback-gui contributors"
            VALUE "OriginalFilename", "@VER_FILENAME@"
            VALUE "ProductName", "sf4e rollback netplay (sf4-rollback-gui)"
            VALUE "ProductVersion", "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
